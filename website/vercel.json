{
  "name": "luisdepombo",
  "alias": "luisdepombo.vercel.app",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "routes": [
    {
      "src": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "luis-eduardo-de-pombo-puerta.vercel.app"
        }
      ],
      "dest": "https://luisdepombo.vercel.app/$1",
      "status": 308
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
